# ─── Meta (Facebook) tracking — ALL OPTIONAL ────────────────────────────────
# Tracking silently no-ops when these are unset, so the site runs fine without
# them. NEVER commit real values — set them only as environment variables
# (e.g. Railway project variables). Secrets must never live in the repo.

# Public Pixel ID used by the browser Pixel (exposed to the client at build time).
# Both names should hold the SAME pixel id:
#   - VITE_META_PIXEL_ID    → read by the frontend (Vite inlines VITE_* vars)
#   - TRENDING_META_PIXEL_ID → read by the backend (CAPI + feed)
VITE_META_PIXEL_ID=
TRENDING_META_PIXEL_ID=

# Conversions API access token (BACKEND SECRET — never expose to the client).
# Generate in Meta Events Manager → Settings → Conversions API.
TRENDING_META_CAPI_ACCESS_TOKEN=

# Optional: test event code from Events Manager → Test Events. When set, CAPI
# events show up in the Test Events tab for debugging. Leave blank in production.
TRENDING_META_TEST_EVENT_CODE=

# ─── TikTok tracking — ALL OPTIONAL ─────────────────────────────────────────
# Parallel to the Meta block above. Tracking silently no-ops when these are
# unset, so the site runs fine without them. NEVER commit real values — set them
# only as environment variables (e.g. Railway project variables). Secrets must
# never live in the repo.

# Public Pixel ID used by the browser Pixel (exposed to the client at build time).
# Both names should hold the SAME pixel id:
#   - VITE_TIKTOK_PIXEL_ID    → read by the frontend (Vite inlines VITE_* vars)
#   - TRENDING_TIKTOK_PIXEL_ID → read by the backend (Events API event_source_id)
VITE_TIKTOK_PIXEL_ID=
TRENDING_TIKTOK_PIXEL_ID=

# Events API access token (BACKEND SECRET — never expose to the client).
# Generate in TikTok Events Manager → your pixel → Settings → Events API.
TRENDING_TIKTOK_EVENTS_API_ACCESS_TOKEN=

# Optional: test event code from TikTok Events Manager → Test Events. When set,
# Events API events show up in the Test Events tab for debugging. Leave blank in
# production.
TRENDING_TIKTOK_TEST_EVENT_CODE=

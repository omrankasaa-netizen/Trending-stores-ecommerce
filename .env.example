# ─── Meta (Facebook) tracking — ALL OPTIONAL ────────────────────────────────
# Tracking silently no-ops when these are unset, so the site runs fine without
# them. NEVER commit real values — set them only as environment variables
# (e.g. Railway project variables). Secrets must never live in the repo.

# Public Pixel ID used by the browser Pixel (exposed to the client at build time).
# Both names should hold the SAME pixel id:
#   - VITE_META_PIXEL_ID    → read by the frontend (Vite inlines VITE_* vars)
#   - TRENDING_META_PIXEL_ID → read by the backend (CAPI + feed)
VITE_META_PIXEL_ID=
TRENDING_META_PIXEL_ID=

# Conversions API access token (BACKEND SECRET — never expose to the client).
# Generate in Meta Events Manager → Settings → Conversions API.
TRENDING_META_CAPI_ACCESS_TOKEN=

# Optional: test event code from Events Manager → Test Events. When set, CAPI
# events show up in the Test Events tab for debugging. Leave blank in production.
TRENDING_META_TEST_EVENT_CODE=

# ─── TikTok tracking — ALL OPTIONAL ─────────────────────────────────────────
# Parallel to the Meta block above. Tracking silently no-ops when these are
# unset, so the site runs fine without them. NEVER commit real values — set them
# only as environment variables (e.g. Railway project variables). Secrets must
# never live in the repo.

# Public Pixel ID used by the browser Pixel (exposed to the client at build time).
# Both names should hold the SAME pixel id:
#   - VITE_TIKTOK_PIXEL_ID    → read by the frontend (Vite inlines VITE_* vars)
#   - TRENDING_TIKTOK_PIXEL_ID → read by the backend (Events API event_source_id)
VITE_TIKTOK_PIXEL_ID=
TRENDING_TIKTOK_PIXEL_ID=

# Events API access token (BACKEND SECRET — never expose to the client).
# Generate in TikTok Events Manager → your pixel → Settings → Events API.
TRENDING_TIKTOK_EVENTS_API_ACCESS_TOKEN=

# Optional: test event code from TikTok Events Manager → Test Events. When set,
# Events API events show up in the Test Events tab for debugging. Leave blank in
# production.
TRENDING_TIKTOK_TEST_EVENT_CODE=

# ─── Core server — REQUIRED IN PRODUCTION ───────────────────────────────────
# Set these as Railway variables (Service → Variables). NEVER commit real
# values; the placeholders below are documentation only.

# SQLite database location. On Railway, point this at the mounted volume, e.g.
# DATABASE_PATH=/data/trending-store.db (MINIYO_DB_PATH is the legacy alias and
# is still honored). Leave empty to use the repo-local default (ephemeral on
# Railway — not suitable for production).
DATABASE_PATH=
MINIYO_DB_PATH=

# JWT signing secret for auth sessions. REQUIRED in production — the server
# refuses to boot without it. Use a long random string (e.g. 64+ chars from
# `openssl rand -hex 48`). Outside production a dev-only fallback is used.
MINIYO_JWT_SECRET=<set-a-long-random-secret>

# Initial admin account, seeded on first boot. MINIYO_ADMIN_PASSWORD is
# REQUIRED in production — if unset, admin seeding is skipped with a loud
# warning (no default password exists anymore). Change the password after
# first login.
MINIYO_ADMIN_EMAIL=admin@trending.store
MINIYO_ADMIN_PASSWORD=<set-a-strong-password>

# Resend transactional email key (order confirmations, OTP). Optional — email
# silently no-ops when unset. Set the real value only in Railway.
RESEND_API_KEY=<your-resend-api-key>

# ─── Cloudflare R2 media storage — REQUIRED IN PRODUCTION ───────────────────
# All five vars must be set for R2 to activate (otherwise uploads fall back to
# ephemeral local disk). Set the real values only in Railway. See
# RAILWAY_PERSISTENCE.md for the full setup walkthrough.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL of the bucket — the custom domain connected to the R2 bucket.
# New uploads are baked with this host, and the boot-time migration
# (server/r2HostMigration.js) rewrites any stored URLs still on the legacy
# r2.dev host to this value.
R2_PUBLIC_BASE_URL=https://images.trending-store.com
# Optional; derived from the account id when omitted.
R2_ENDPOINT=

# Copy this file to .env.local (client) / configure in your deployment platform (server).
# NEVER commit real secrets. All real values belong in your platform's environment variables.

# --- Client (Vite, build-time) ---
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=your_backend_url
# VITE_BASE44_FUNCTIONS_VERSION=

# --- Server (runtime) ---
# JWT signing secret. MUST be set to a strong random value in production.
# The code falls back to a dev-only placeholder if unset — do NOT rely on that outside local dev.
MINIYO_JWT_SECRET=change-me-to-a-strong-random-value

# Resend transactional email. If unset, emails are logged-only (flow still succeeds).
RESEND_API_KEY=your_resend_api_key
MINIYO_EMAIL_FROM=Trending Store <orders@yourdomain.com>

# Seed admin account (set before first boot).
MINIYO_ADMIN_EMAIL=admin@yourdomain.com
MINIYO_ADMIN_PASSWORD=change-me

# Optional
# MINIYO_DB_PATH=/data/data.db
# MINIYO_ORDER_ALERT_EMAILS=alerts@yourdomain.com
# MINIYO_JOURNAL_MODE=DELETE
# TRENDING_SUPER_ADMIN_EMAILS=owner@yourdomain.com
# PORT=4000
